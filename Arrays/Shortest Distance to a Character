class Solution:
    def shortestToChar(self, s: str, c: str):

        pos = []
        for i in range(len(s)):
            if s[i] == c:
                pos.append(i)

        ans = []
        for i in range(len(s)):

            mini = 100000
            for j in pos:

                d = abs(i - j)

                if d < mini:
                    mini = d

            ans.append(mini)

        return ans