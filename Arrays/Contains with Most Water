def maxArea(self, height: List[int]) -> int:
        i=0
        j=len(height)-1
        ans=0
        while i<j:
            width=j-i
            h=min(height[i],height[j])
            area=width*h
            if area>ans:
                ans=area

            if height[i]<height[j]:
                i=i+1
            else:
                j=j-1

        return ans