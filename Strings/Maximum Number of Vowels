class Solution:
    def maxVowels(self, s: str, k: int) -> int:
        v="aeiouAEIOU"
        c=0
        for l in range(k):
            if s[l] in v:
                c+=1
        maxi=c
        for i in range(k,len(s)):
            if s[i-k] in v:
                c-=1
            if s[i] in v:
                c+=1
            if c>maxi:
                maxi=c
        return maxi